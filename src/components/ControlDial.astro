---
import { getCollection } from "astro:content";
import { components, dialLabels } from "../data/components";

const offerings = (await getCollection("offerings")).sort(
  (a, b) => a.data.order - b.data.order,
);
const defaultIndex = 0; // Passive Reporting (the entry-level end of the dial)
---

<div class="dial" data-dial>
  <div class="dial__endpoints">
    <span>◀ You run it</span>
    <span>We run it ▶</span>
  </div>

  <div class="dial__track">
    <div class="dial__rail" aria-hidden="true"></div>
    <div class="dial__stops" role="tablist" aria-label="Support level">
      {
        offerings.map((o, i) => (
          <button
            type="button"
            class="dial__stop"
            role="tab"
            id={`dial-tab-${i}`}
            aria-controls={`dial-pane-${i}`}
            data-index={i}
            aria-pressed={i === defaultIndex ? "true" : "false"}
          >
            {o.data.label}
          </button>
        ))
      }
    </div>
  </div>

  {
    offerings.map((o, i) => (
      <div
        class="dial__detail"
        id={`dial-pane-${i}`}
        role="tabpanel"
        aria-labelledby={`dial-tab-${i}`}
        data-pane={i}
        hidden={i !== defaultIndex}
      >
        <p class="kicker">{dialLabels[o.data.dial]}</p>
        <p style="font-family:var(--display);font-size:clamp(1.5rem,4vw,2.4rem);line-height:1;margin-bottom:0.5rem">
          {o.data.oneLiner}
        </p>
        <p style="max-width:40em">{o.data.pitch}</p>
        <dl class="dial__matrix">
          {
            components.map((c) => (
              <div class="dial__matrix__row">
                <dt>{c.label}</dt>
                <dd>{o.data.matrix[c.key]}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    ))
  }
</div>

<script>
  const root = document.querySelector<HTMLElement>("[data-dial]");
  if (root) {
    const stops = Array.from(
      root.querySelectorAll<HTMLButtonElement>(".dial__stop"),
    );
    const panes = Array.from(
      root.querySelectorAll<HTMLElement>(".dial__detail[data-pane]"),
    );

    function select(i: number) {
      stops.forEach((s, idx) => {
        const on = idx === i;
        s.setAttribute("aria-pressed", String(on));
      });
      panes.forEach((p, idx) => {
        p.hidden = idx !== i;
      });
    }

    stops.forEach((s, i) =>
      s.addEventListener("click", () => select(i)),
    );

    root.addEventListener("keydown", (e) => {
      if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
      e.preventDefault();
      const current = stops.findIndex(
        (s) => s.getAttribute("aria-pressed") === "true",
      );
      const next =
        e.key === "ArrowLeft"
          ? (current - 1 + stops.length) % stops.length
          : (current + 1) % stops.length;
      select(next);
      stops[next].focus();
    });
  }
</script>