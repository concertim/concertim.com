---
import { site, footerNav } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="wrap site-footer__grid">
    <div>
      <a href="/" class="brand" aria-label={site.name}>
        <img src="/images/cIM_Logo_01.png" alt={site.name} />
      </a>
      <p class="muted" style="margin-top:1rem;max-width:22em">
        HPC & AI services, as a subscription. You decide how much we run.
      </p>
      <p class="muted" style="font-family:var(--mono);font-size:0.8rem">
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </p>
    </div>

    <div>
      <h3>Site</h3>
      <ul>
        {
          footerNav.site.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h3>Legal</h3>
      <ul>
        {
          footerNav.legal.map((item) => (
            <li>
              <a href={item.href}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="wrap site-footer__bottom">
    <span>© {year} {site.legalName}. All rights reserved.</span>
    <span>Reg. {site.companyNumber}</span>
  </div>
</footer>