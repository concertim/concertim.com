---
// Full-page riso grain / halftone overlay. Inline SVG feTurbulence, fixed,
// pointer-events none, blended multiply at low opacity. See .grain in global.css.
---

<div class="grain" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
    <filter id="grain-noise">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.9"
        numOctaves="2"
        stitchTiles="stitch"
      ></feTurbulence>
      <feColorMatrix type="saturate" values="0"></feColorMatrix>
    </filter>
    <rect width="100%" height="100%" filter="url(#grain-noise)"></rect>
  </svg>
</div>