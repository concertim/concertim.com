---
import Base from "../layouts/Base.astro";
import { getEntry, render } from "astro:content";

const page = await getEntry("pages", "privacy");
const hero = page?.data.hero;
let Body: any = null;
if (page) {
  const { Content } = await render(page);
  Body = Content;
}
---

<Base title={page?.data.title ?? "Privacy Policy"} description={page?.data.description}>
  <section class="page-hero">
    <div class="wrap">
      {hero && <span class="kicker">{hero.kicker}</span>}
      <h1 class="riso" data-text={hero?.headline ?? "Privacy Policy"}>
        {hero?.headline ?? "Privacy Policy"}
      </h1>
      {hero?.sub && <p style="max-width:34em;font-size:1.2rem">{hero.sub}</p>}
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      {Body && <div class="prose"><Body /></div>}
    </div>
  </section>
</Base>